# Configuration Prof Chez Vous - Production Render
# Copiez ce fichier en .env et remplissez les valeurs réelles

# Sécurité Django
SECRET_KEY=your-secret-key-here-min-50-characters
DEBUG=False

# Database Render (PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database_name

# Allowed Hosts (séparés par des virgules)
ALLOWED_HOSTS=pcv.onrender.com

# Configuration Allauth
SITE_ID=1

# Email (optionnel pour production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
